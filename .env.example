PRIVATE_KEY=0x...                          # Deployer private key (testnet only!)
DEPLOYER_ADDRESS=0x...                     # Public address matching PRIVATE_KEY

ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

RPC=$ARBITRUM_SEPOLIA_RPC

ARBISCAN_API_KEY=your_arbiscan_key        # for --verify on forge script

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

ERC8004_REPUTATION=

# в”Ђв”Ђ Deployed contract addresses (fill in after forge script Deploy.s.sol) в”Ђв”Ђв”Ђв”Ђв”Ђ
VAULT_FACTORY=0x...
PILOT_REGISTRY=0x...
CONSERVATIVE_RWA=0x...
ORACLE_ADDRESS=0x...

# в”Ђв”Ђ Demo vault (fill in after scripts/setup-vault.sh) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Optional. Pin the runtime to ONE vault. Leave EMPTY to auto-discover every
# vault that hired this pilot (the runtime scans VaultFactory.allVaults and keeps
# the ones whose active charter names it).
VAULT_ADDRESS=0x...

# в”Ђв”Ђ Token addresses вЂ” Arbitrum Sepolia в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
AAVE_POOL=0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff
A_USDC_ADDRESS=0x460b97BD498E1157530AEb3086301d5225b91216

# в”Ђв”Ђ Frontend (Next.js) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Copy these from the forge script output into /web/.env.local
NEXT_PUBLIC_VAULT_FACTORY=$VAULT_FACTORY
NEXT_PUBLIC_PILOT_REGISTRY=$PILOT_REGISTRY
NEXT_PUBLIC_CONSERVATIVE_RWA=$CONSERVATIVE_RWA
NEXT_PUBLIC_ORACLE=$ORACLE_ADDRESS
NEXT_PUBLIC_USDC=$USDC_ADDRESS
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=$ARBITRUM_SEPOLIA_RPC
NEXT_PUBLIC_CHAIN_ID=421614

# в”Ђв”Ђ Pilot runtime в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PILOT_PRIVATE_KEY=0x...                   # Session key used by pilot to call executePlan
POLL_INTERVAL_MS=15000                    # How often pilot checks for drift (15s for demo)
DISCOVERY_INTERVAL_MS=60000               # Auto-discovery mode: how often to re-scan the factory for newly hired/revoked vaults

# Target allocation in bps (must sum to 10000)
# Default: 50% idle USDC / 50% in Aave вЂ” lets the pilot rebalance both directions
TARGET_USDC_BPS=5000
TARGET_AUSDC_BPS=5000

# в”Ђв”Ђ Indexer / DB в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DATABASE_URL=postgresql://pilotage:pilotage@localhost:5432/pilotage
PORT=3001
